{
  "name": "devpulse",
  "version": "1.0.0",
  "description": "DevPulse API - Node.js + Express + PostgreSQL",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node22 --outfile=dist/server.js --format=esm --packages=external",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.24.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}